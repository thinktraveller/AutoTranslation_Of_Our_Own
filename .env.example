# ATO3 API Key 配置模板
# 复制本文件为 .env，填入你的真实 API Key
# 注意：.env 文件绝对不能提交到 Git 仓库

# OpenAI API Key（若使用 OpenAI 服务）
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepSeek API Key（若使用 DeepSeek 服务）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 其他 OpenAI-compatible 提供商（按需添加）
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
